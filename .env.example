# DashScope / Qwen
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# Paths
DATA_DIR=data
MD5_RECORD_PATH=runtime/md5.text

# Text splitting
CHUNK_SIZE=500
CHUNK_OVERLAP=80
MAX_SPLIT_THRESHOLD=500

# Retrieval
RETRIEVAL_TOP_K=3
RETRIEVAL_CANDIDATES=10
ROUTER_MATCH_THRESHOLD=0.55

# Models
# You can also use local model directories, for example:
# EMBEDDING_MODEL=./models/bge-m3
# RERANKER_MODEL=./models/bge-reranker-v2-m3
EMBEDDING_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
CHAT_MODEL=qwen3-max

# HuggingFace model cache, optional. Set these if you want large local models away from C drive.
HF_HOME=
HF_HUB_CACHE=
SENTENCE_TRANSFORMERS_HOME=
HF_HUB_DISABLE_SYMLINKS_WARNING=1
HF_HUB_DISABLE_XET=1
# If huggingface.co is unstable in your network, uncomment and set a mirror.
# HF_ENDPOINT=https://hf-mirror.com

# Redis answer cache
REDIS_ENABLED=true
REDIS_URL=redis://localhost:6379/0
CHAT_CACHE_TTL_SECONDS=3600

# Milvus
MILVUS_URI=http://localhost:19530
MILVUS_TOKEN=
MILVUS_DB_NAME=default
MILVUS_COLLECTION=agent_knowledge
DENSE_VECTOR_DIM=1024
DENSE_WEIGHT=0.6
SPARSE_WEIGHT=0.4

# MCP map/weather tools
MCP_ENABLED=true
MCP_TRANSPORT=http
MCP_URL=https://mcp.amap.com/mcp
AMAP_MAPS_API_KEY=your_amap_maps_api_key_here

# Optional public IP override. Leave empty to auto-detect.
IP=

# MySQL chat history
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=your_mysql_user_here
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DATABASE=rag_agent
MYSQL_CHARSET=utf8mb4
